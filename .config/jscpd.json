{
  "$schema": "https://unpkg.com/jscpd@latest/schemas/jscpd.json",
  "threshold": 6,
  "reporters": ["console"],
  "absolute": false,
  "gitignore": true,
  "format": ["python"],
  "min-tokens": 50,
  "min-lines": 8,
  "ignore": [
    "**/.venv/**",
    "**/node_modules/**",
    "**/__pycache__/**",
    "**/tests/**",
    "**/*.generated.py",
    "**/coverage.xml",
    "docs/**",
    ".claude/**",
    ".similar-report.json"
  ]
}
